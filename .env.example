# Copy to state/agent.env (gitignored) and fill in. Loaded by the orchestrator.
# Only OPENROUTER_API_KEY is strictly required; the rest have sensible defaults.

# --- LLM (required) -----------------------------------------------------------
# OpenRouter key for the apply agent. Watch for HTTP 402 (out of credit).
OPENROUTER_API_KEY=sk-or-...
# Override the apply model / loop limits if needed.
# APPLY_MODEL=z-ai/glm-5.2
# APPLY_MAX_TURNS=60
# APPLY_TIMEOUT_SECONDS=900
# APPLY_REASONING_EFFORT=
# Reject listings whose text clearly describes a studio/one-room layout.
# Ambiguous or missing layout text remains eligible (fail-open).
# REQUIRE_SEPARATE_BEDROOM=1

# --- Identity / notifications -------------------------------------------------
# Google account used for "Sign in with Google" SSO on source sites.
GOOGLE_ACCOUNT=you@example.com
# Where status emails are sent (defaults to you@example.com). Set NOTIFY_ENABLED=0 to mute.
NOTIFY_TO=you@example.com
# NOTIFY_ENABLED=1

# --- Applicant profile (overrides src/applicant_profile.py defaults) ----------
# APPLICANT_NAME=Jane Doe
# APPLICANT_AGE=30
# APPLICANT_NATIONALITY=Dutch
# APPLICANT_GROSS_MONTHLY_INCOME=4000.00
# APPLICANT_EMPLOYMENT=permanent contract (vast contract)
# APPLICANT_HOUSEHOLD_SIZE=1
# APPLICANT_IS_STUDENT=0
# APPLICANT_IS_WONINGDELER=0
# APPLICANT_HAS_PETS=0
# APPLICANT_SMOKER=0

# --- Paths --------------------------------------------------------------------
# Where your application documents live (defaults to ./documents).
# DOCS_DIR=

# --- VPS / deploy (used by the justfile and CI; not needed for local dev) ------
# VPS_HOST=root@your-server-ip
# VPS_SSH_KEY_PATH=~/.ssh/id_ed25519
# VPS_REMOTE_DIR=/home/deploy/browser-agent
# DASHBOARD_DOMAIN=your-agent.example.org
