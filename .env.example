# Common runtime settings. Copy to state/agent.env on the VPS; systemd loads
# that file for the orchestrator and dashboard. For local `just` variables,
# use a separate .env file. Never commit either file.
#
# `src/settings.py` is the complete source of truth for names and defaults.
# Run `just settings` to print the values resolved in the current environment.

# --- LLM (required for apply, playbooks, credit checks, and LiteLLM) ---------
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# APPLY_MODEL=deepseek-v4-pro
# APPLY_MAX_TURNS=60
# APPLY_TIMEOUT_SECONDS=900
# APPLY_REASONING_EFFORT=off
# APPLY_MAX_TOKENS=8000

# --- Applicant policy --------------------------------------------------------
# MAX_RENT=1750
# Reject only listings whose text clearly proves a studio/one-room layout.
# Ambiguous or missing layout text remains eligible (fail-open).
# REQUIRE_SEPARATE_BEDROOM=0

# --- Identity and notifications --------------------------------------------
GOOGLE_ACCOUNT=you@example.com
NOTIFY_TO=you@example.com
# NOTIFY_ENABLED=1
# WEB_PUSH_ENABLED=1
# WEB_PUSH_OUTCOMES=submitted

# --- Applicant profile -------------------------------------------------------
# These override defaults in src/applicant_profile.py.
# APPLICANT_NAME=Jane Doe
# APPLICANT_AGE=30
# APPLICANT_NATIONALITY=Dutch
# APPLICANT_GROSS_MONTHLY_INCOME=4000.00
# APPLICANT_EMPLOYMENT=permanent contract (vast contract)
# APPLICANT_HOUSEHOLD_SIZE=1
# APPLICANT_IS_STUDENT=0
# APPLICANT_IS_WONINGDELER=0
# APPLICANT_HAS_PETS=0
# APPLICANT_SMOKER=0

# --- Paths -------------------------------------------------------------------
# Defaults to ./documents. Contents are private and gitignored.
# DOCS_DIR=

# --- Optional runtime subsystems --------------------------------------------
# SELF_IMPROVEMENT_ENABLED=1
# SELF_IMPROVEMENT_ALLOW_CODE_CHANGES=1
# SELF_IMPROVEMENT_ALLOW_DEPLOY=1
# SESSION_KEEPER_ENABLED=1
# HEALTHCHECK_PING_URL=

# --- Local just/VPS operations (.env, not state/agent.env) ------------------
# VPS_HOST=root@your-server-ip
# VPS_SSH_KEY_PATH=~/.ssh/id_ed25519
# VPS_REMOTE_DIR=/home/deploy/browser-agent
# DASHBOARD_DOMAIN=your-agent.example.org
